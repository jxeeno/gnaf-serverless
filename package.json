{
	"name": "gnaf-serverless",
	"description": "Serverless Australian address (GNAF) lookup API on Cloudflare Workers",
	"dependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-router": "^1.163.3",
		"@tanstack/react-router-devtools": "^1.163.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"hono": "4.11.1",
		"leaflet": "^1.9.4",
		"lucide-react": "^0.575.0",
		"radix-ui": "^1.4.3",
		"react": "19.2.1",
		"react-dom": "19.2.1",
		"react-leaflet": "^5.0.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@aws-sdk/client-s3": "^3.1000.0",
		"@cloudflare/vite-plugin": "1.15.3",
		"@duckdb/node-api": "^1.4.4-r.2",
		"@eslint/js": "9.39.1",
		"@tanstack/router-plugin": "^1.164.0",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^24.11.0",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@types/unzipper": "^0.10.11",
		"@vitejs/plugin-react": "5.1.1",
		"eslint": "9.39.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"shadcn": "^3.8.5",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "5.8.3",
		"typescript-eslint": "8.48.0",
		"unzipper": "^0.12.3",
		"vite": "^6.0.0",
		"vitest": "^4.0.18",
		"wrangler": "^4.69.0"
	},
	"private": true,
	"scripts": {
		"build": "tsc -b && vite build",
		"cf-typegen": "wrangler types",
		"check": "tsc && vite build && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "vite",
		"lint": "eslint .",
		"preview": "npm run build && vite preview",
		"pipeline:download": "tsx scripts/pipeline/download.ts",
		"pipeline:import": "tsx scripts/pipeline/import.ts",
		"pipeline:shard": "tsx scripts/pipeline/shard.ts",
		"pipeline:upload": "tsx scripts/pipeline/upload.ts",
		"pipeline:search-index": "tsx scripts/pipeline/search-index.ts",
		"pipeline:run": "tsx scripts/pipeline/run.ts",
		"test": "vitest run --config vitest.config.ts",
		"test:watch": "vitest --config vitest.config.ts"
	},
	"type": "module"
}
