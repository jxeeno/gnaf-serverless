{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gnaf-s3-query",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"build": {
		"watch_dir": [
			"src/worker",
			"src/shared",
			"src/react-app",
			"src/components"
		]
	},
	"routes": [
		{
			"pattern": "gnaf.k3n.au",
			"custom_domain": true
		}
	],
	"vars": {
		"SHARD_PREFIX_LENGTH": "3"
	},
	"d1_databases": [
		{
			"binding": "SEARCH_DB",
			"database_name": "gnaf-search",
			"database_id": "b3061346-8fd8-4fc2-bbaa-1f3af23d4759"
		}
	]
}
