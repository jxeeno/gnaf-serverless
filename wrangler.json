{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gnaf-s3-query",
	"main": "./src/worker/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"routes": [
		{
			"pattern": "gnaf.k3n.au",
			"custom_domain": true
		}
	],
	"vars": {
		"GNAF_VERSION": "v20260301",
		"SHARD_PREFIX_LENGTH": "3"
	}
}
